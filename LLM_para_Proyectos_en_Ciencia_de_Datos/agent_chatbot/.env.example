# Elige un proveedor para ADK Web: Gemini o un endpoint compatible con OpenAI.
GOOGLE_API_KEY=
CHATBOT_MODEL=gemini-2.5-flash
# Opcional para modelos locales mediante LiteLLM.
LMSTUDIO_MODEL=
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Necesaria sólo para búsquedas web reales mediante el servidor MCP.
TAVILY_API_KEY=
TAVILY_MAX_RESULTS=3
