# Se usa para generar respuestas y para el agente ADK.
GOOGLE_API_KEY=
RAG_MODEL=gemini-2.5-flash
# Puede ser el mismo modelo de generación o uno distinto para el LLM-as-a-Judge.
RAG_JUDGE_MODEL=gemini-2.5-flash

# Modelo local descargado automáticamente por sentence-transformers la primera vez.
RAG_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
