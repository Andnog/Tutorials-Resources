GOOGLE_API_KEY=
DEFAULT_GEMINI_MODEL=gemini-3.1-flash-lite
LMSTUDIO_BASE_URL=http://localhost:1234/v1
DEFAULT_LMSTUDIO_MODEL=local-model
# LM Studio normalmente acepta cualquier valor; cámbialo si tu endpoint autentica.
LMSTUDIO_API_KEY=lm-studio
# Opcional: URI de MLflow. Por defecto se usa SQLite local: ./mlflow.db.
MLFLOW_TRACKING_URI=
# `registry` (predeterminado) carga la versión `staging` desde MLflow Prompt
# Registry. Usa `markdown` sólo para una demostración completamente offline.
MLFLOW_PROMPT_SOURCE=registry
MLFLOW_PROMPT_ALIAS=staging
# Opcional: CA corporativa personalizada si el certificado de Gemini no se
# valida en tu red. Por defecto se usa el bundle de certifi automáticamente.
ADK_SSL_CA_FILE=
# Para Judges LLM configurados desde la UI se crea un Gateway endpoint en
# MLflow; no se coloca aquí una clave del proveedor.
